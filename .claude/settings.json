{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/harness/plugin/runtime/hooks/session-start.mjs\"",
            "timeout": 30,
            "statusMessage": "加载 harness 启动检查"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/harness/plugin/runtime/hooks/pre-write.mjs\"",
            "timeout": 30,
            "statusMessage": "执行写入前治理检查"
          }
        ]
      },
      {
        "matcher": "Grep|Read|Glob",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/harness/plugin/runtime/hooks/pre-explore.mjs\"",
            "timeout": 10,
            "statusMessage": "检查代码探索是否已委托 subagent"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/harness/plugin/runtime/hooks/post-write.mjs\"",
            "timeout": 60,
            "statusMessage": "执行写入后治理检查"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/harness/plugin/runtime/hooks/stop.mjs\"",
            "timeout": 30,
            "statusMessage": "检查完成前验证状态"
          }
        ]
      }
    ]
  }
}
