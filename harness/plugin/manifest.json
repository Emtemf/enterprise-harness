{
  "name": "enterprise-harness-runtime",
  "version": "0.1.0",
  "description": "Portable runtime adapter for the Enterprise Harness project contract.",
  "supportedOs": ["linux", "darwin", "win32"],
  "requiredRuntime": {
    "node": ">=20"
  },
  "requiredProjectFiles": [
    "CLAUDE.md",
    ".claude/settings.json",
    "harness/config.yaml",
    "harness/specs/plugin-runtime.md"
  ],
  "optionalProjectFiles": [
    ".mcp.json",
    "harness/ACTIVE_CHANGE"
  ],
  "commands": {
    "cli": "node harness/plugin/runtime/cli.mjs",
    "doctor": "node harness/plugin/runtime/cli.mjs doctor",
    "bootstrap": "node harness/plugin/runtime/cli.mjs bootstrap",
    "sync": "node harness/plugin/runtime/cli.mjs sync",
    "setupLocalAdapter": "node harness/plugin/runtime/cli.mjs setup-local-adapter --write",
    "install": "node harness/plugin/runtime/cli.mjs install --write-local-adapter",
    "upgrade": "node harness/plugin/runtime/cli.mjs upgrade",
    "migrate": "node harness/plugin/runtime/cli.mjs migrate",
    "upstreamCheck": "node harness/plugin/runtime/upstream-check.mjs",
    "lifecycle": "node harness/plugin/runtime/cli.mjs lifecycle",
    "context7": "node harness/plugin/runtime/cli.mjs context7"
  },
  "requiredEnvVars": [],
  "notes": [
    "Project secrets must not be committed to the repository.",
    "Context7 may run through CLI wrappers when MCP is not configured.",
    "This manifest describes the portable runtime layer, not the repo contract itself."
  ]
}
